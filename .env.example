# ── Embedding ──
EMBEDDING_BASEURL=
EMBEDDING_MODEL=  
EMBEDDING_API_KEY=
EMBEDDING_TOP_K=10             # optional, not set = ChromaDB default (10)
EMBEDDING_INPUT_TOKEN=8192     # optional, not set = code default (8192)

# ── Rerank ──
RERANK_BASEURL=
RERANK_MODEL=
RERANK_API_KEY=
RERANK_TOP_K=5                 # optional, not set = return all results
RERANK_SCORE_THRESHOLD=0.0     # optional, not set = no threshold filter
RERANK_INPUT_TOKEN=8192        # optional, not set = code default (8192)
CONFIDENCE_THRESHOLD=0.3       # optional, not set = 0.3

# ── Database ──
DATABASE_PATH=./database       # optional, defaults to ./database
